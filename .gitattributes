# Normalize text files; keep repository content consistent
* text=auto

# Source and config files: LF for Linux friendliness
*.c      text eol=lf
*.cc     text eol=lf
*.cpp    text eol=lf
*.h      text eol=lf
*.hpp    text eol=lf
*.inl    text eol=lf
*.txt    text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.xml    text eol=lf
*.sh     text eol=lf
*.py     text eol=lf
*.cmake  text eol=lf

# Windows scripts
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf

# Visual Studio/MSBuild files: CRLF to avoid noisy diffs in VS
*.sln        text eol=crlf
*.vcxproj    text eol=crlf
*.vcproj     text eol=crlf
*.props      text eol=crlf
*.targets    text eol=crlf
*.filters    text eol=crlf
*.user       text eol=crlf

# Treat build outputs and common binaries as binary
*.dll    binary
*.lib    binary
*.exp    binary
*.pdb    binary
*.iobj   binary
*.ipdb   binary
*.obj    binary
*.exe    binary
*.so     binary
*.a      binary
*.o      binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.zip    binary
*.7z     binary